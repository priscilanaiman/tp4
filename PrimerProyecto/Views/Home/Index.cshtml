<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Album</title>
</head>
<body>
    <h1>Album de figuritas</h1>
    @foreach(Figurita figu in ViewBag.figusTotales)
    {
        if(figu.Cantidad > 1)
        {
            <img src="figu.Imagen">
        }
        else
        {
            <img src="/images/figu vacia.png">
        }
    }
    <br>
    <a class="boton" href='@Url.Action("sobre", "Home")'>Abrir Sobres </a>
</body>
</html>