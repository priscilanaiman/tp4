<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Figuritas</title>
</head>
<body>
    <h2>Te tocaron...</h2>
    <form method="post" action="@Url.Action("Confirmar", "Home")">
        @foreach (Figurita figurita in ViewBag.figuritas)
        {
            <img src="@figurita.Imagen" alt="Figurita" />
            <input type="hidden" name="figuritaId" value="@figurita.Id" />
        }
        <br>
        <input type="submit" value="Confirmar" class="boton" />
    </form>
</body>
</html>